# Port for the FastAPI gateway
PORT=8000

# Base URL for Ollama local service
OLLAMA_BASE_URL=http://localhost:11434

# Secret API Key required to authenticate requests to this gateway
API_KEY=your_generated_secret_api_key_here

# Selected Gemma 4 model
GEMMA_MODEL=gemma4:e4b

# Bitwarden Master Password (TOP SECRET - used by deploy/sync_secrets.py)
BW_PASSWORD=your_bitwarden_master_password_here
