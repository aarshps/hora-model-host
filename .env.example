# =============================================================================
# Hora Model Host — Gateway Environment
# Copy to `.env` and fill in. The .env file is gitignored.
# =============================================================================

# Port the FastAPI gateway listens on (UFW must allow this externally).
PORT=8000

# Internal URL for the Ollama daemon. Keep on localhost; UFW should block
# this port from the public internet.
OLLAMA_BASE_URL=http://localhost:11434

# Secret bearer token clients must send as `Authorization: Bearer <KEY>`.
# Generate with:
#   python -c "import secrets; print(f'hora_live_{secrets.token_hex(16)}')"
API_KEY=your_generated_secret_api_key_here

# Primary Ollama model tag served by this deployment.
# Pick something appropriate for your VPS — see wiki/Choosing-a-Model.
#   Fast & light (4-10 t/s on 12-core CPU):  qwen2.5:7b-instruct, phi-4-mini, llama3.2:3b
#   Balanced:                                gemma2:9b, qwen2.5:14b
#   Heavy (slow on CPU):                     qwen3.6:35b, gemma4:31b
MODEL_ID=qwen2.5:7b-instruct

# Human-friendly name shown in the gateway's discovery endpoints.
DEPLOYMENT_NAME=Hora Model Host

# -----------------------------------------------------------------------------
# Optional secrets (only required for specific scripts)
# -----------------------------------------------------------------------------

# Bitwarden master password — used by deploy/sync_secrets.py to vault `.env`
# and SSH keys. Leave empty if you don't use the Bitwarden sync flow.
BW_PASSWORD=

# Telegram bot token — used by deploy/setup_telegram_bot.sh when wiring up
# OpenClaw or Hermes Agent. Get from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------------------------
# Backward-compatible aliases (deprecated, still honored)
# -----------------------------------------------------------------------------
# GEMMA_MODEL=  # legacy name for MODEL_ID — only used if MODEL_ID is unset
