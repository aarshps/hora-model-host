# Force LF line endings on text files that get executed on Linux servers.
# Without this, Windows checkouts would commit CRLF, and bash on the VPS
# would fail with "/usr/bin/env: 'bash\r': No such file or directory".

* text=auto eol=lf

*.sh        text eol=lf
*.py        text eol=lf
*.service   text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
.env*       text eol=lf

# Mark these scripts as executable in the git tree so they don't need
# `chmod +x` after clone on Linux.
deploy/*.sh         eol=lf
deploy/*.py         eol=lf
